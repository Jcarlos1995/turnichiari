rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOSS() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'oss';
    }
    // Single get() covers both role and nucleo ownership — avoids double read per write check
    function canWrite(nucleoId) {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isAuth() && (u.role == 'coordinatrice' || (u.role == 'raa' && u.nucleoId == nucleoId));
    }
    function isCoordinatrice() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coordinatrice';
    }

    // Users: read own profile; coordinatrice reads all
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isCoordinatrice());
      // RAA can create OSS profiles in their own nucleo; only coordinatrice can update/delete
      allow create: if isAuth() &&
        'nucleoId' in request.resource.data &&
        'role' in request.resource.data &&
        request.resource.data.role == 'oss' &&
        canWrite(request.resource.data.nucleoId);
      allow update, delete: if isCoordinatrice();
    }

    // Nuclei: all authenticated read; RAA writes own; coordinatrice writes all
    match /nuclei/{nucleoId} {
      allow read: if isAuth();
      allow write: if canWrite(nucleoId);

      match /operators/{operatorId} {
        allow read: if isAuth();
        allow write: if canWrite(nucleoId);
      }

      match /matrice/{yearMonth} {
        allow read: if isAuth();
        // Phase 2: add Cloud Function trigger to enforce updatedBy == auth.uid
        // and validate payload shape (code from allowed list, day 1–31)
        allow write: if canWrite(nucleoId);
      }

      match /requests/{requestId} {
        allow read: if isAuth();
        allow create: if isOSS();
        allow update: if canWrite(nucleoId);
      }
    }

    // Audit log: write only by Functions; read by coordinatrice
    match /audit/{logId} {
      allow read: if isCoordinatrice();
      allow write: if false;
    }
  }
}
